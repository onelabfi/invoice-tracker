# ─── DATABASE ────────────────────────────────────────────────────────────────
# Supabase → Settings → Database → Connection string (Transaction pooler — required for serverless)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...            # safe to expose — enforced by RLS
SUPABASE_SERVICE_ROLE_KEY=eyJ...                # NEVER expose — server-only

# ─── AI ───────────────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
# Set to "true" to block all /api/ask requests instantly (no deploy needed)
AI_DISABLED=false

# ─── UPSTASH REDIS ────────────────────────────────────────────────────────────
# console.upstash.com → Database → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ─── BANK PROVIDERS ───────────────────────────────────────────────────────────
# GoCardless/Nordigen → bankaccountdata.gocardless.com → Developers
NORDIGEN_SECRET_ID=
NORDIGEN_SECRET_KEY=

# Tink → console.tink.com → API clients
TINK_CLIENT_ID=
TINK_CLIENT_SECRET=

# TrueLayer → console.truelayer.com → Applications
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=

# Plaid → dashboard.plaid.com → Team → Keys
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ─── APP ──────────────────────────────────────────────────────────────────────
# Production frontend URL — used for CORS origin header
NEXT_PUBLIC_APP_URL=https://app.ricordo.fi
