generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  supabaseId      String?          @unique // auth.users.id UUID — bridge for Storage RLS
  name            String
  email           String           @unique
  role            String           @default("owner") // owner, employee, accountant
  createdAt       DateTime         @default(now())
  invoices        Invoice[]
  bankConnections BankConnection[]
  transactions    Transaction[]
  notifications   Notification[]
}

model Invoice {
  id                String    @id @default(cuid())
  vendor            String
  amount            Float
  currency          String    @default("EUR")
  invoiceNumber     String?
  description       String?
  dueDate           DateTime?
  iban              String?
  reference         String?
  status            String    @default("unpaid") // unpaid, paid, overdue, duplicate, reminder
  paidAt            DateTime?
  isReminder        Boolean   @default(false)
  reminderFee       Float?
  originalInvoiceId String?
  originalInvoice   Invoice?  @relation("ReminderOf", fields: [originalInvoiceId], references: [id])
  reminders         Invoice[] @relation("ReminderOf")
  source            String    @default("upload") // upload, camera, email, manual
  fileName          String?
  fileUrl           String?
  storagePath       String?   // Supabase Storage path — use /api/invoices/[id]/file-url for signed URL
  rawText           String?
  confidence        Float?
  userId            String?
  user              User?     @relation(fields: [userId], references: [id])
  matches           Match[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Transaction {
  id              String          @id @default(cuid())
  bankAccount     String?
  merchant        String
  amount          Float
  reference       String?
  description     String?
  date            DateTime
  rawData         String?
  connectionId    String?
  userId          String?
  user            User?           @relation(fields: [userId], references: [id])
  matches         Match[]
  createdAt       DateTime        @default(now())
}

model BankConnection {
  id                String    @id @default(cuid())
  bankName          String
  accountName       String?
  status            String    @default("connected") // connected, syncing, error, disconnected
  provider          String    @default("manual")    // nordigen, plaid, csv, manual, tink, truelayer
  country           String?
  institutionId     String?
  externalId        String?   // requisition_id (nordigen) or item_id (plaid) or tinkUserId
  accessToken       String?
  accountExternalId String?   // external account ID from provider
  lastSynced        DateTime?
  userId            String?
  user              User?     @relation(fields: [userId], references: [id])
  createdAt         DateTime  @default(now())
}

model Notification {
  id            String   @id @default(cuid())
  title         String
  message       String
  type          String   @default("info")
  invoiceId     String?
  read          Boolean  @default(false)
  actionType    String?
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // CREATE_INVOICE, DELETE_INVOICE, UPLOAD_FILE, CONNECT_BANK, etc.
  resourceId String?
  ip         String?
  userAgent  String?
  metadata   String?  // JSON — extra context (amounts, providers, error codes, etc.)
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

model Match {
  id              String      @id @default(cuid())
  invoiceId       String
  invoice         Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  confidenceScore Float
  matchType       String      // reference, amount, merchant, combined
  createdAt       DateTime    @default(now())

  @@unique([invoiceId, transactionId])
}
